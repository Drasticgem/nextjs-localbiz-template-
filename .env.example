# Copy this file to .env.local and replace placeholder values.
# Vercel users: add the same variables under Project Settings → Environment Variables.

# --- Contact form (required for the /contact + CTA forms to send email) ---
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
# Where contact submissions are delivered
CONTACT_TO_EMAIL=owner@company.com
# Verified sender address in Resend (the "From" header)
CONTACT_FROM_EMAIL=Website Leads <leads@your-domain.com>

# --- Branding (optional) ---
# Exposed to the browser — used for display only, not for secrets
NEXT_PUBLIC_COMPANY_NAME=COMPANY_NAME
# Public site URL (e.g., https://example.com) — reserve for future metadata/sitemap
# NEXT_PUBLIC_SITE_URL=https://example.com
